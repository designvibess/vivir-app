# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Override model IDs if needed (defaults shown)
ANTHROPIC_QUALITY_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: Supabase project → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Exposed to browser (must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Direct Postgres URL for Drizzle migrations
# From: Supabase project → Settings → Database → Connection string → URI (direct, not pooled)
SUPABASE_DB_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres

# ─── Azure Speech Services ────────────────────────────────────────────────────
# From: Azure portal → Cognitive Services → Speech resource → Keys and Endpoint
AZURE_SPEECH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_SPEECH_REGION=westeurope

# ─── ElevenLabs ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_...
# Voice ID for La Profesora (choose a Castilian Spanish voice from ElevenLabs library)
ELEVENLABS_VOICE_ID=

# ─── PostHog Analytics ────────────────────────────────────────────────────────
# From: PostHog project → Project settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Development overrides ───────────────────────────────────────────────────
# Set to "true" to use mock providers instead of real APIs (saves cost during dev)
# USE_MOCK_AI=true
# USE_MOCK_STT=true
# USE_MOCK_TTS=true
